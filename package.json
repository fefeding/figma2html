{
  "name": "@fefeding/figma2html",
  "version": "1.0.1",
  "description": "figma 转 html 工具类",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "dev": "node test/dev",
    "build": "gulp",
    "build:esm": "node ./build/build.js",
    "api:json": "npx api-extractor run",
    "api:md": "npx api-documenter markdown -i ./docs/.api -o ./docs/api && node ./build/md.js",
    "api": "npm run api:json && npm run api:md",
    "push": "npm publish --registry=https://registry.npmjs.org"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-function-bind": "^7.27.1",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-stage-0": "^7.8.3",
    "@microsoft/api-documenter": "^7.29.6",
    "@microsoft/api-extractor": "^7.57.6",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@types/node": "^20.19.35",
    "babel-preset-env": "^1.7.0",
    "babel-preset-es2015": "^6.24.1",
    "babel-preset-stage-0": "^6.24.1",
    "babelify": "^10.0.0",
    "browserify": "^17.0.1",
    "express": "^4.22.1",
    "gulp": "^4.0.2",
    "gulp-babel": "^8.0.0",
    "gulp-cli": "^2.3.0",
    "gulp-concat": "^2.6.1",
    "gulp-typescript": "6.0.0-alpha.1",
    "rollup": "^4.59.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "tsify": "^5.0.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vinyl-source-stream": "^2.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@fefeding/css-filters": "^1.0.7",
    "@fefeding/utils": "^1.0.39"
  },
  "author": "fefeding",
  "license": "MIT"
}
